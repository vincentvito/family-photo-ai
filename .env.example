# Replicate token — serves BOTH Nano Banana Pro (google/nano-banana-pro) for
# photoreal generation + refinement, AND the stylized/upscale models.
# Grab one at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Default provider. Accepts: nanobanana | replicate | mock
DEFAULT_PROVIDER=nanobanana

# Set to "1" to skip all real API calls and return canned placeholder images.
# Useful for UI development without burning credits.
NEXT_PUBLIC_MOCK_MODE=0
